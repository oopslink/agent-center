# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/

# VitePress 站点构建产物（sites/ 隔离的脚手架）
sites/node_modules/
sites/.vitepress/dist/
sites/.vitepress/cache/

# VitePress 在仓库根生成的缓存（CWD 漂移时的产物）
.vitepress/

# Build output
/bin/

# Release tarballs from `make release` (host-platform output).
/dist/

# SPA build output baked by go:embed — populated by `make build-frontend`.
# .gitkeep stays so the directory exists for go:embed to find.
/internal/webconsole/spa/dist/*
!/internal/webconsole/spa/dist/.gitkeep

# Throwaway dir used by scripts/lint/test-no-vendor-refs.sh. The script
# cleans it up via trap, but guard against accidentally committing
# leftover sample files if a run is interrupted.
/scripts/lint/.selftest/

# UI/UX Pro Max skill — Python bytecode cache
.claude/skills/*/scripts/__pycache__/

# local agent worktrees (per-session, never part of the repo)
.claude/worktrees/
