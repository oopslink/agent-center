[Unit]
Description=agent-center daily backup
After=agent-center.service
Wants=agent-center.service

[Service]
Type=oneshot
User=agent-center
Group=agent-center
ExecStart=/usr/local/bin/agent-center admin backup --dest=/var/backups/agent-center --retention-days=30 --config=/etc/agent-center/config.yaml
StandardOutput=journal
StandardError=journal
SyslogIdentifier=agent-center-backup
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/agent-center /var/backups/agent-center
